# Copy to .env.local for local dev. .env / .env.* are gitignored (except this
# example) — never commit real secrets, and never put the Discord webhook here.

# Formspree endpoint (PUBLIC — safe to expose). This is the primary, server-side
# delivery path; it emails you each booking. Falls back to this value in code.
VITE_FORMSPREE_ENDPOINT=https://formspree.io/f/xgojkepa

# OPTIONAL serverless Discord proxy URL (PUBLIC — safe to expose). This is the
# URL of YOUR deployed proxy (see serverless/README.md), NOT the Discord webhook.
# The proxy holds the real webhook as a server-side secret. Leave blank to use
# Formspree-only (email) delivery until the proxy is set up.
VITE_DISCORD_PROXY_URL=
